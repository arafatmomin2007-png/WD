<?php
// Display welcome message
echo "<h2>Welcome to My Web Page!</h2>";
// Set timezone (important)
date_default_timezone_set("Asia/Kolkata");
// Display current date and time
echo "<p>Current Date & Time: " . date("d-m-Y H:i:s") . "</p>";
?> 
 
PHP opening and closing tags
<?php  ?>
Everything inside these tags is PHP code.
Display welcome message
echo "Welcome to PHP Programming";
echo is used to display output on the webpage.
Set timezone
date_default_timezone_set("Asia/Kolkata");
Sets the time according to India.
Display current date and time
date("d-m-Y h:i:s A");
•	d = day 
•	m = month 
•	Y = year 
•	h = hour 
•	i = minutes 
•	s = seconds 
•	A = AM/PM 
